rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default-deny safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helper methods
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == "adiladil02360@gmail.com"
      );
    }

    // Collection matching
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /donations/{donationId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /growthGoals/{goalId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if (
        isAdmin() || 
        (request.resource.data.currentAmount >= resource.data.currentAmount && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentAmount']))
      );
    }

    match /opportunities/{opportunityId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if (
        isAdmin() || 
        (request.resource.data.appliesCount == resource.data.appliesCount + 1 && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['appliesCount']))
      );
    }

    match /applications/{applicationId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /stories/{storyId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if (
        isAdmin() || 
        (request.resource.data.likes == resource.data.likes + 1 ||
         request.resource.data.likes == resource.data.likes - 1) && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes'])
      );
    }

    match /proofGallery/{proofId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
